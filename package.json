{
	"name": "obsidian-notion-plugin",
	"version": "1.0.2",
	"description": "Bidirectional sync between Obsidian Markdown notes and multiple Notion databases.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"build:release": "node scripts/build-release.mjs",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint src vitest.config.ts eslint.config.mts"
	},
	"keywords": [],
	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "9.30.1",
		"@types/node": "^20.19.35",
		"@vitest/coverage-v8": "^4.0.18",
		"esbuild": "0.25.5",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"jiti": "2.6.1",
		"jsdom": "^27.4.0",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"vitest": "^4.0.18"
	},
	"dependencies": {
		"@notionhq/client": "^5.11.1",
		"obsidian": "latest",
		"yaml": "^2.8.2"
	}
}
